# bff.fluxcy.xyz - Express BFF app (apps/server)
# Cambia "YOUR_CPANEL_USER" por tu usuario real de cPanel.
# Verifica la ruta exacta del binario Node en "Setup Node.js App".

# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/YOUR_CPANEL_USER/fluxcy_dashboard/apps/server"
PassengerBaseURI "/"
PassengerNodejs "/home/YOUR_CPANEL_USER/nodevenv/bff.fluxcy.xyz/22/bin/node"
PassengerAppType node
PassengerStartupFile server.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION BEGIN
<IfModule Litespeed>
SetEnv NODE_ENV production
</IfModule>
# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION END
