# Base URL del origen de datos externo usado por las rutas /api internas de Next.js
# EXTERNAL_API_BASE_URL=http://api-sermaca.lat/api_aguilera/api

# Credenciales de trial WellTech (solo servidor; no exponer al cliente)
WELLTECH_USERNAME=welltech
WELLTECH_PASSWORD=welltech123

# Secreto para firma de sesion/trial (JWT HS256)
AUTH_SECRET=replace_with_a_long_random_secret

# API nueva WellTech (origen). Si no incluyes sufijo, el router agrega /fluxcy/api
WELLTECH_API_BASE_URL=http://api.fluxcy.xyz

# Fallback del trial (America/Caracas), usado cuando falta wt_trial
TRIAL_FALLBACK_START=2026-02-27T11:00:00-04:00

# Opcional: BFF externo (si quieres proxyear por rewrites en lugar del modo integrado)
# BFF_URL=https://tu-bff.example.com
# NEXT_PUBLIC_BFF_URL=https://tu-bff.example.com

# Opcional: URL de Socket.IO externo
# NEXT_PUBLIC_SOCKET_URL=https://tu-bff.example.com

# Opcional: habilitar backend remoto de tareas
# NEXT_PUBLIC_ENABLE_TASKS_BACKEND=false
