# Backend base URL (BFF) used by Next.js rewrites in production
BFF_URL=https://tu-bff.example.com

# Public URL only needed if you want direct browser access (for example Socket.IO)
# If omitted in production, Socket.IO will try same-origin (/socket.io)
# NEXT_PUBLIC_BFF_URL=https://tu-bff.example.com
# NEXT_PUBLIC_SOCKET_URL=https://tu-bff.example.com

# Optional: enable remote task CRUD endpoint integration
# NEXT_PUBLIC_ENABLE_TASKS_BACKEND=false
